{
  "name": "@cortexkit/pi-antigravity-auth",
  "version": "2.0.0",
  "description": "Google Antigravity OAuth extension for pi - access Gemini 3 and Claude 4.6 using Google credentials",
  "type": "module",
  "license": "MIT",
  "author": "CortexKit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortexkit/antigravity-auth.git",
    "directory": "packages/pi"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "google",
    "antigravity",
    "gemini",
    "oauth",
    "claude"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --format=esm --external:@earendil-works/* --external:@cortexkit/antigravity-auth-core --outfile=dist/index.js --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "bun test --isolate ./src",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@cortexkit/antigravity-auth-core": "2.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.1",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@earendil-works/pi-tui": "^0.79.1",
    "esbuild": "^0.27.7"
  }
}
