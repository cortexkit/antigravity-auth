{
  "name": "@cortexkit/opencode-antigravity-auth",
  "version": "2.0.0",
  "description": "Google Antigravity OAuth auth plugin for OpenCode - access Gemini 3 and Claude 4.6 using Google credentials",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "author": "CortexKit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cortexkit/antigravity-auth.git",
    "directory": "packages/opencode"
  },
  "homepage": "https://github.com/cortexkit/antigravity-auth#readme",
  "bugs": {
    "url": "https://github.com/cortexkit/antigravity-auth/issues"
  },
  "keywords": [
    "opencode",
    "google",
    "antigravity",
    "gemini",
    "oauth",
    "plugin",
    "auth",
    "claude"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild index.ts --bundle --platform=node --format=esm --external:@openauthjs/* --external:zod --outfile=dist/index.js --sourcemap",
    "build:schema": "bunx tsx script/build-schema.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --isolate ./src",
    "prepublishOnly": "bun run build",
    "test:e2e:models": "bunx tsx script/test-models.ts",
    "test:e2e:regression": "bunx tsx script/test-regression.ts"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.13",
    "@opentui/core": "^0.4.5",
    "@opentui/keymap": "^0.4.5",
    "@opentui/solid": "^0.4.5",
    "typescript": "^5 || ^6"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "zod-to-json-schema": "^3.25.1"
  },
  "dependencies": {
    "@cortexkit/antigravity-auth-core": "2.0.0",
    "@openauthjs/openauth": "^0.4.3",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.0.0"
  }
}
